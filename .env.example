# Local helper config for fastdis tools.
# Copy to .env or .env.local and adjust for your machine.

# Default Unreal lane. Keep this on the version you want most helpers to use.
# For this repo, 5.8 is the current primary lane.
FASTDIS_UNREAL_EDITOR="/Users/Shared/Epic Games/UE_5.8/Engine/Binaries/Mac/UnrealEditor"
FASTDIS_UNREAL_ENGINE_DIR="/Users/Shared/Epic Games/UE_5.8"

# Optional explicit Unreal matrix lanes. The helper scripts accept
# --engine-version 5.6 / 5.7 / 5.8 and will look for these first.
FASTDIS_UNREAL_EDITOR_5_6="/Users/Shared/Epic Games/UE_5.6/Engine/Binaries/Mac/UnrealEditor"
FASTDIS_UNREAL_ENGINE_DIR_5_6="/Users/Shared/Epic Games/UE_5.6"
FASTDIS_UNREAL_EDITOR_5_7="/Users/Shared/Epic Games/UE_5.7/Engine/Binaries/Mac/UnrealEditor"
FASTDIS_UNREAL_ENGINE_DIR_5_7="/Users/Shared/Epic Games/UE_5.7"
FASTDIS_UNREAL_EDITOR_5_8="/Users/Shared/Epic Games/UE_5.8/Engine/Binaries/Mac/UnrealEditor"
FASTDIS_UNREAL_ENGINE_DIR_5_8="/Users/Shared/Epic Games/UE_5.8"

# Junior-friendly workflow:
# 1. copy this file to .env.local
# 2. adjust the paths for your machine
# 3. run `python tools/unreal_workflow.py doctor`
# 4. run `python tools/unreal_workflow.py full --engine-version 5.8`

FASTDIS_GODOT="/opt/homebrew/bin/godot"
FASTDIS_SCONS="/opt/homebrew/bin/scons"
FASTDIS_GODOT_WORK_ROOT="/tmp/fastdis_godot"
FASTDIS_RIDER="/Users/rick/Library/Application Support/JetBrains/Toolbox/scripts/rider"

# Godot junior-friendly workflow:
# 1. copy this file to .env.local
# 2. adjust the paths for your machine
# 3. run `python tools/godot_workflow.py doctor`
# 4. run `python tools/godot_workflow.py full`

# Unity Hub editor lanes. The helper scripts also auto-discover common Unity Hub
# locations, but explicit env vars make CI and junior-machine setup clearer.
FASTDIS_UNITY_EDITOR="/Applications/Unity/Hub/Editor/6000.5.0f1/Unity.app"
FASTDIS_UNITY_EDITOR_6000_3="/Applications/Unity/Hub/Editor/6000.3.18f1/Unity.app"
FASTDIS_UNITY_EDITOR_6000_5="/Applications/Unity/Hub/Editor/6000.5.0f1/Unity.app"

# Unity junior-friendly workflow:
# 1. copy this file to .env.local
# 2. adjust the paths for your machine
# 3. run `python tools/unity_workflow.py discover`
# 4. run `python tools/unity_workflow.py full --unity-version 6000.5`

# Optional Windows wheel cross-build lane from macOS/Linux.
# Set FASTDIS_MINGW_PREFIX if your MinGW tool names differ from the default
# x86_64-w64-mingw32-* names.
# FASTDIS_MINGW_PREFIX="x86_64-w64-mingw32"
#
# Junior-friendly Windows wheel workflow:
# 1. install cmake + mingw-w64
# 2. run `python tools/windows_wheel_workflow.py doctor`
# 3. run `python tools/windows_wheel_workflow.py full --no-isolation`
