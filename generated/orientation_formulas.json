      [
        "Mul(Integer(-1), sin(Symbol('lon', real=True)))",
        "cos(Symbol('lon', real=True))",
        "Integer(0)"
      ],
      [
        "Mul(Integer(-1), sin(Symbol('lat', real=True)), cos(Symbol('lon', real=True)))",
        "Mul(Integer(-1), sin(Symbol('lat', real=True)), sin(Symbol('lon', real=True)))",
        "cos(Symbol('lat', real=True))"
      ],
      [
        "Mul(cos(Symbol('lat', real=True)), cos(Symbol('lon', real=True)))",
        "Mul(sin(Symbol('lon', real=True)), cos(Symbol('lat', real=True)))",
        "sin(Symbol('lat', real=True))"
      ]
