integrations/unity/**/Runtime/Plugins/**/*.dll.meta
integrations/unity/**/Runtime/Plugins/**/*.dylib
integrations/unity/**/Runtime/Plugins/**/*.dylib.meta
integrations/unity/**/Runtime/Plugins/**/*.so
integrations/unity/**/Runtime/Plugins/**/*.so.meta

