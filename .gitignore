# FASTDIS keeps generated artifacts out of git, while source examples for
# Python, C/C++, Unreal, Unity, and Godot remain trackable.

# OS metadata
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100/
.Trashes/
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Editor and IDE state
.idea/
.vscode/
*.code-workspace
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.fleet/

# Local environment and secrets
.env
.env.*
!.env.example
.python-version
.tool-versions

# External competitor/source-route checkouts are local operator dependencies,
# not tracked FastDIS source.
external/grill/

# Logs, temp files, and archives
*.log
*.tmp
*.temp
*.bak
*.orig
*.rej
*.pid
*.seed
*.pid.lock
tmp/
temp/
.cache/
.sass-cache/
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar
node_modules/

# Python bytecode, virtualenvs, packaging, and test caches
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.hypothesis/
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/
.nox/
.tox/
.venv/
venv/
env/
ENV/
pip-wheel-metadata/
site/
dist/
build/
build-*/
wheelhouse/
C:\fastdis_godot/

# Generated/operator outputs are ignored under artifacts/. Historical root-level
# output directories remain ignored as legacy locations.
artifacts/
benchmark_reports/
benchmark_results/
release_artifacts/
verification_reports/

# Generated schema- and analysis-derived outputs stay local unless they are
# intentionally promoted into maintained source inputs.
generated/*.json
generated/* 2.json
generated/* 2/
generated/**/* 2.json
generated/**/* 2/
generated/differential_report.json
generated/differential_report.md
generated/fuzz_shallow_corpus/

# Native C/C++/CMake build outputs
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
DartConfiguration.tcl
Testing/
compile_commands.json
install_manifest.txt
cmake-build-*/
out/
Debug/
Release/
RelWithDebInfo/
MinSizeRel/
