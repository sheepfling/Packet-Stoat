#!/usr/bin/env python
# Minimal SCons scaffold for a Godot 4 GDExtension that links fastdis.
# The built wrapper library is emitted directly into the demo project's
# addons/fastdis/bin directory so the sample project can load it immediately.

import os

env = SConscript("godot-cpp/SConstruct") if os.path.exists("godot-cpp/SConstruct") else Environment()

env.Append(CPPPATH=[
    "src",
    os.environ.get("FASTDIS_INCLUDE", "../../include"),
    os.environ.get("GODOT_CPP_INCLUDE", "godot-cpp/include"),
    os.environ.get("GODOT_CPP_GEN_INCLUDE", "godot-cpp/gen/include"),
    os.environ.get("GODOT_CPP_GDEXTENSION_INCLUDE", "godot-cpp/gdextension"),
])

env.Append(CXXFLAGS=["-std=c++17"])

fastdis_lib_dir = os.environ.get("FASTDIS_LIB_DIR", "../../build")
env.Append(LIBPATH=[fastdis_lib_dir])

demo_bin_dir = "../fastdis_demo/addons/fastdis/bin"

if env.get("platform") == "windows":
    env.Append(LIBS=["fastdis"])
    target = demo_bin_dir + "/fastdis_gdextension.windows.template_debug.x86_64.dll"
elif env.get("platform") == "macos":
    env.Append(LIBS=["fastdis"])
    target = demo_bin_dir + "/libfastdis_gdextension.macos.template_debug.dylib"
else:
    env.Append(LIBS=["fastdis"])
    env.Append(RPATH=["$ORIGIN"])
    target = demo_bin_dir + "/libfastdis_gdextension.linux.template_debug.x86_64.so"

sources = [
    "src/register_types.cpp",
    "src/fastdis_world.cpp",
]

env.SharedLibrary(target=target, source=sources)
