<patches>
  <class
    name="InformationOperationsReportPdu"
    inheritsFrom="InformationOperationsFamilyPdu"
    comment="FastDIS local patch: restore the DIS 7 Information Operations Report PDU class so generation can treat standard row 71 as schema-backed. Evidence: upstream OpenDIS source-generator XML defines the field order and the generated Java confirms the mixed enum widths and trailing IORecord packing."
  >
    <initialValue name="pduType" value="71" />

    <attribute name="ioSimSource" comment="IO simulation source">
      <primitive type="unsigned short" />
    </attribute>

    <attribute name="ioReportType" comment="IO report type">
      <primitive type="unsigned byte" />
    </attribute>

    <attribute name="padding1" comment="padding">
      <primitive type="unsigned byte" />
    </attribute>

    <attribute name="ioAttackerID" comment="IO attacker identifier">
      <classRef name="EntityID" />
    </attribute>

    <attribute name="ioPrimaryTargetID" comment="IO primary target identifier">
      <classRef name="EntityID" />
    </attribute>

    <attribute name="padding2" comment="padding">
      <primitive type="unsigned short" />
    </attribute>

    <attribute name="padding3" comment="padding">
      <primitive type="unsigned short" />
    </attribute>

    <attribute name="numberOfIORecords" comment="number of IO records">
      <primitive type="unsigned short" />
    </attribute>

    <attribute name="ioRecords" comment="IO records">
      <list type="variable" countFieldName="numberOfIORecords">
        <classRef name="IORecord" />
      </list>
    </attribute>
  </class>
</patches>
