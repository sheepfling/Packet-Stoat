    <attribute name="systemSpecificDataLength"><primitive type="unsigned byte" /></attribute>
    <attribute name="systemSpecificData"><list type="variable" countFieldName="systemSpecificDataLength"><primitive type="unsigned byte" /></list></attribute>
  </class>
