    <attribute name="liveEntityId"><classRef name="EntityID" /></attribute>
    <attribute name="TSPIFlag"><primitive type="unsigned byte" /></attribute>
    <attribute name="entityLocation"><classRef name="LiveEntityRelativeWorldCoordinates" /></attribute>
    <attribute name="entityLinearVelocity"><classRef name="LiveEntityLinearVelocity" /></attribute>
