linux.release.x86_64 = "res://addons/fastdis/bin/libfastdis_gdextension.linux.template_release.x86_64.so"
windows.debug.x86_64 = "res://addons/fastdis/bin/fastdis_gdextension.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://addons/fastdis/bin/fastdis_gdextension.windows.template_release.x86_64.dll"
macos.debug = "res://addons/fastdis/bin/libfastdis_gdextension.macos.template_debug.dylib"
macos.release = "res://addons/fastdis/bin/libfastdis_gdextension.macos.template_release.dylib"
