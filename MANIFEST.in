include LICENSE README.md CMakeLists.txt packaging_helpers.py
recursive-include include *.h *.hpp
recursive-include cmake/toolchains *.cmake
recursive-include src/native *.cpp
recursive-include src/fastdis *.py *.c
recursive-include src/fastdis *.dll *.dylib *.so*
recursive-include docs *.md
recursive-include tests *.py *.cpp *.json
recursive-include examples *.py *.c *.cpp *.h *.cs *.Build.cs *.uplugin *.gdextension *.sample *.md *.json *.sha256
recursive-include .github/workflows *.yml

recursive-include bindings *.py *.md
recursive-include c *.h *.c *.cpp *.md
recursive-include fuzz *.cpp *.hpp *.md
recursive-include tools *.py
recursive-include references/open-dis *.xml *.md

recursive-include benchmarks *.cpp *.py *.md

recursive-include examples SConstruct

prune generated
prune benchmark_reports
prune benchmark_results
prune release_artifacts
prune verification_reports
prune src/*.egg-info
prune examples/godot/fastdis_gdextension/godot-cpp
prune examples/godot/fastdis_demo/addons/fastdis/bin
prune examples/godot/fastdis_orientation_verification/addons/fastdis/bin
prune examples/unreal/FastDis/Intermediate
prune examples/unreal/FastDis/ThirdParty
prune examples/unreal/FastDisOrientationVerification/Intermediate
prune examples/unreal/FastDisOrientationVerification/Plugins
prune examples/unreal/FastDisOrientationVerification/Saved

global-exclude __pycache__/*
global-exclude *.py[cod]
global-exclude *.so
global-exclude *.so.*
global-exclude *.dylib
global-exclude *.dll
global-exclude .DS_Store
